# Copy this file to .env.local for local dev, or set these as env vars on Vercel

# Backend API URL (your VPS domain or IP)
NEXT_PUBLIC_API_URL=https://api.yourdomain.com

# Stripe publishable key (pk_live_... for production, pk_test_... for staging)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_<YOUR_STRIPE_PUBLISHABLE_KEY>
